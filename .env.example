# Telegram ariza yuborish sozlamalari (backendsiz).
# Bu faylni `.env.local` nomi bilan nusxalang va qiymatlarni to'ldiring.
# .env.local GitHub'ga YUKLANMAYDI (.gitignore da).

# @BotFather dan olingan bot tokeni
VITE_TELEGRAM_BOT_TOKEN=

# Kanal/guruh ID (masalan: -1001234567890). Bot o'sha kanalda ADMIN bo'lishi shart.
VITE_TELEGRAM_CHAT_ID=
